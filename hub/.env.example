# Copy to .env and pick a transport. .env is gitignored.
#
# Preferred: USB serial (CDC-ACM). The board streams JSON telemetry over the USB
# gadget — board data never touches Wi-Fi. The host exposes it as /dev/ttyACM0.
SERIAL_DEV=/dev/ttyACM0

# Fallback: HTTP poll over the LAN. Comment out SERIAL_DEV above and set this to
# the board's IP (also drop `devices:` and `user:` in docker-compose.yml).
#BOARD_HOST=192.168.0.50
#BOARD_PORT=8080

INSTALLER_PORT=8090
POLL_INTERVAL=3
STALE_AFTER=8
HUB_PORT=8091
