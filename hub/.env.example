# Copy to .env and edit. .env is gitignored.
#
# Primary path is the USB-gadget link: plug the board's USB into the host and it
# comes up at 192.168.9.1 (the host side is 192.168.9.2). This keeps board data
# off Wi-Fi entirely — the whole point of a "connected" device.
BOARD_HOST=192.168.9.1     # USB-gadget link (preferred). Wi-Fi LAN IP also works.
BOARD_PORT=8080
INSTALLER_PORT=8090
POLL_INTERVAL=3
HUB_PORT=8091
