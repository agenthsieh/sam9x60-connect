#!/bin/busybox sh
# PID 1 for the QSPI recovery installer initramfs (USB-serial variant).
# Shebang MUST be /bin/busybox (there is no /bin/sh yet).
export PATH=/bin:/sbin:/usr/bin:/usr/sbin:$PATH
/bin/busybox mount -t devtmpfs dev /dev 2>/dev/null
/bin/busybox mount -t proc proc /proc 2>/dev/null
/bin/busybox mount -t sysfs sysfs /sys 2>/dev/null
/bin/busybox --install -s 2>/dev/null
mkdir -p /tmp /mnt

# LEDs off, then blue = "installer ready" (keep each ≤15 mA)
for c in red green blue; do echo none > /sys/class/leds/$c/trigger 2>/dev/null; done

echo ""; echo "=== SAM9X60 QSPI RECOVERY INSTALLER (serial) ==="

# CDC-ACM gadget. The full recovery kernel has these as modules; load in order
# (libcomposite is built in). use_acm=1 → the host binds it as /dev/ttyACM0.
insmod /lib/modules/u_serial.ko 2>/dev/null
insmod /lib/modules/usb_f_acm.ko 2>/dev/null
insmod /lib/modules/usb_f_serial.ko 2>/dev/null
insmod /lib/modules/g_serial.ko use_acm=1 2>/dev/null
for i in 1 2 3 4 5; do [ -e /dev/ttyGS0 ] && break; sleep 1; done

echo 0 > /sys/class/leds/red/brightness 2>/dev/null
echo 1 > /sys/class/leds/blue/brightness 2>/dev/null
echo "[installer] USB-serial ready on /dev/ttyGS0; push a provisioning .swu from the hub"
echo "  >> manual return to SD: mount /dev/mmcblk0p1 /mnt && mv /mnt/boot.bin.off /mnt/boot.bin && sync && reboot -f"

# Serial agent handles telemetry-style heartbeat + file push + provisioning.
# It reads /dev/ttyGS0; Ctrl-C on the ttyS0 console drops to the rescue shell.
/sbin/installer-agent.sh

# agent exited -> interactive rescue shell on the serial console, forever
while true; do /bin/busybox sh </dev/ttyS0 >/dev/ttyS0 2>&1; /bin/busybox sleep 1; done
