#!/bin/busybox sh
# PID 1 for the QSPI recovery installer initramfs.
# Shebang MUST be /bin/busybox (there is no /bin/sh yet — busybox --install
# creates the applet symlinks below, but this script runs before that).
export PATH=/bin:/sbin:/usr/bin:/usr/sbin:$PATH
/bin/busybox mount -t devtmpfs dev /dev 2>/dev/null
/bin/busybox mount -t proc proc /proc 2>/dev/null
/bin/busybox mount -t sysfs sysfs /sys 2>/dev/null
/bin/busybox --install -s 2>/dev/null
mkdir -p /tmp /www /mnt

# LEDs off, then blue = "installer ready" (keep each ≤15 mA)
for c in red green blue; do echo none > /sys/class/leds/$c/trigger 2>/dev/null; done

echo ""; echo "=== SAM9X60 QSPI RECOVERY INSTALLER ==="
/bin/busybox sleep 2

# USB-gadget link. usb0 exists because USB_ETH is built into the recovery
# kernel; no module load needed. No DHCP server here (busybox has no udhcpd) —
# the host sets 192.168.9.2 statically, or a future build delivers the .swu
# from a locally-mounted disk instead of over the network.
/sbin/ip addr add 192.168.9.1/24 dev usb0 2>/dev/null
/sbin/ip link set usb0 up 2>/dev/null
echo "[installer] USB gadget: usb0 = 192.168.9.1  (host set 192.168.9.2, push .swu to :8090)"

# SWUpdate web server for delivery (same engine as the A/B OTA half).
/usr/bin/swupdate -v -w "-r /www -p 8090" -B none >/tmp/swupdate.log 2>&1 &

echo 0 > /sys/class/leds/red/brightness 2>/dev/null
echo 0 > /sys/class/leds/green/brightness 2>/dev/null
echo 1 > /sys/class/leds/blue/brightness 2>/dev/null

echo ""
echo "  >> return to SD: mount /dev/mmcblk0p1 /mnt && mv /mnt/boot.bin.off /mnt/boot.bin && sync && reboot -f"
echo ""

# Interactive rescue shell on the serial console, forever.
while true; do /bin/busybox sh </dev/ttyS0 >/dev/ttyS0 2>&1; /bin/busybox sleep 1; done
